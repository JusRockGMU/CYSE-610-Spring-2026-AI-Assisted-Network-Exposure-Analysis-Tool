# ============================================
# AI-Assisted Network Exposure Analysis
# Environment Configuration
# ============================================

# REQUIRED: Anthropic API Key
# Get your key from: https://console.anthropic.com/
# This enables AI-powered vulnerability explanations and Q&A
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OPTIONAL: NVD API Key (for higher rate limits)
# Get free key from: https://nvd.nist.gov/developers/request-an-api-key
# Without key: 5 requests/30 seconds
# With key: 50 requests/30 seconds
# NVD_API_KEY=your-nvd-api-key-here

# ============================================
# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and replace "your-anthropic-api-key-here" with your actual key
# 3. Save the file
# 4. Run: make build
# 5. Run: make run
# ============================================
